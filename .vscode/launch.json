{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension: Cloude Code ToolBox",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/packages/cloude-code-toolbox"],
      "outFiles": ["${workspaceFolder}/packages/cloude-code-toolbox/out/**/*.js"],
      "preLaunchTask": "npm: compile - cloude-code-toolbox"
    }
  ]
}
