%% Cursor vs Claude Code capability map (Cloude Code ToolBox)
%% Source of truth for the diagram; export PNG to screenshots/mermaid-claude-map.png when you want a README image.
%% Render: https://mermaid.live — or: npx -y @mermaid-js/mermaid-cli -i diagrams/mermaid-copilot-map.mmd -o screenshots/mermaid-claude-map.png

flowchart LR
  subgraph cursor_in["Cursor-era inputs"]
    direction TB
    crules[".cursor/rules"]
    cmcp["~/.cursor/mcp.json"]
    cskills[".cursor/skills (optional)"]
  end

  subgraph npm_cli["npm CLIs"]
    direction TB
    port["cursor-mcp-vscode-port"]
    crulescli["cursor-rules-to-claude"]
    gmem["cloude-code-memory-bank"]
  end

  subgraph toolbox["Cloude Code ToolBox"]
    hub["Hub: Intelligence / MCP / Skills / Workspace"]
  end

  subgraph vsc["VS Code + Claude Code"]
    direction TB
    outmcp[".vscode/mcp.json / user mcp.json"]
    claudemd["CLAUDE.md / .claude/"]
    outmb["memory-bank/*.md"]
    legacy[".github/copilot-instructions.md (legacy Copilot)"]
  end

  crules --> crulescli
  cmcp --> port
  port --> outmcp
  crulescli --> claudemd
  gmem --> claudemd
  gmem --> outmb

  hub --> port
  hub --> crulescli
  hub --> gmem

  outmcp --> hub
  claudemd --> hub
  outmb --> hub
  legacy --> hub
